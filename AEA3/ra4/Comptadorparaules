import java.io.*;
import java.util.Scanner;

public class Comptadorparaules {

    public static void main(String[] args) {
        String fitxerEntrada = "entrada.txt";
        String fitxerSortida = "sortida.txt";
        int totalParaules = 0;

  
        try (Scanner lector = new Scanner(new File(fitxerEntrada))) {
            while (lector.hasNext()) {
                lector.next(); 
                totalParaules++;
            }
        } catch (FileNotFoundException e) {
            System.err.println("L'arxiu " + fitxerEntrada + " no s'ha trobat.");
            return; 
        } catch (Exception e) {
            System.err.println("Error durant la lectura: " + e.getMessage());
            return;
        }

        try (PrintWriter escriptor = new PrintWriter(new FileWriter(fitxerSortida))) {
            escriptor.println("El archivo tiene " + totalParaules + " palabras.");
            System.out.println("Operació completada. Recompte: " + totalParaules);
        } catch (IOException e) {
            System.err.println("Error en escriure el fitxer de sortida: " + e.getMessage());
        }
    }
}