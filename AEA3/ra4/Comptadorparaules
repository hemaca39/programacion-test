import java.io.*;
import java.util.Scanner;

public class Comptadorparaules {

    public static void main(String[] args) {
        String nomEntrada = "entrada.txt";
        String nomSortida = "sortida.txt";


        processarComptatge(nomEntrada, nomSortida);
    }


    public static void processarComptatge(String fitxerEntrada, String fitxerSortida) {
        int totalParaules = 0;
        File arxiuEntrada = new File(fitxerEntrada);

        if (!arxiuEntrada.exists()) {
            System.out.println("L'arxiu " + fitxerEntrada + " no s'ha trobat.");
            return;
        }

        try (Scanner lector = new Scanner(arxiuEntrada)) {
            while (lector.hasNext()) {
                lector.next(); 
                totalParaules++;
            }
        } catch (FileNotFoundException e) {
            System.out.println("Eerrror: no s'ha pogut obrir el fitxer.");
        } catch (Exception e) {
            System.out.println("error inesperat durant la lectura: " + e.getMessage());
        }


        try (PrintWriter escriptor = new PrintWriter(new FileWriter(fitxerSortida, false))) {
            escriptor.println("El archivo tiene " + totalParaules + " palabras.");
            System.out.println("operació finalitzada. Resultat escrit a " + fitxerSortida);
        } catch (IOException e) {
            System.out.println("error en escriure al fitxer de sortida: " + e.getMessage());
        }
    }
}